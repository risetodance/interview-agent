# ==================== 服务器配置 ====================
# SSH 连接信息
SERVER_HOST=your_server_ip
SERVER_USER=root

# ==================== Spring Profile 配置 ====================
# 激活的 Spring Profile (dev/prod)
SPRING_PROFILES_ACTIVE=prod

# ==================== 后端配置 ====================
# 后端 Docker 镜像名称和标签
BACKEND_IMAGE_NAME=interview-guide
BACKEND_IMAGE_TAG=latest

# 后端部署目录（服务器上存放 jar 和 Dockerfile 的目录）
BACKEND_DEPLOY_DIR=/opt/interview-guide/app

# ==================== 前端配置 ====================
# 前端部署路径（服务器上的静态资源目录）
FRONTEND_DIST_DIR=/var/www/interview-guide

# 前端调用的后端 API 地址（部署后前端访问的地址）
API_BASE_URL=http://your_server_ip:7777

# ==================== 小程序配置 ====================
# 小程序部署路径
MINIPROGRAM_DIST_DIR=/var/www/interview-guide/miniprogram

# ==================== 数据库配置（服务器已有） ====================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=interview_guide
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here

# ==================== Redis 配置 ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_password_here

# ==================== 对象存储配置 ====================
APP_STORAGE_ENDPOINT=http://localhost:9000
APP_STORAGE_ACCESS_KEY=minioadmin
APP_STORAGE_SECRET_KEY=minioadmin
APP_STORAGE_BUCKET=interview-guide
APP_STORAGE_REGION=us-east-1

# ==================== AI 配置 ====================
MINIMAX_API_KEY=your_api_key_here
MINIMAX_API_HOST=https://api.minimaxi.com

# Embedding 模型配置（可选，不填则使用 MINIMAX_API_KEY）
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-v3

# ==================== 应用配置 ====================
# JWT 密钥（生产环境必须修改）
JWT_SECRET=interview-guide-jwt-secret-key-must-be-at-least-512-bits-long-for-hs512

# CORS 允许的源（前端地址）
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:80

# 面试追问数量
APP_INTERVIEW_FOLLOW_UP_COUNT=1

# MCP 搜索配置
APP_MCP_WEBSEARCH_ENABLED=true

# ==================== 微信小程序配置 ====================
WECHAT_MINIAPP_APPID=your_appid
WECHAT_MINIAPP_SECRET=your_secret

# ==================== 监控配置 ====================
PROMETHEUS_DATA_DIR=/opt/interview-guide/prometheus/data
GRAFANA_DATA_DIR=/opt/interview-guide/grafana/data

# ==================== 存储路径配置 ====================
REDIS_DATA_DIR=/opt/interview-guide/redis/data
REDIS_LOGS_DIR=/opt/interview-guide/redis/logs
POSTGRES_DATA_DIR=/opt/interview-guide/postgres/data
POSTGRES_LOGS_DIR=/opt/interview-guide/postgres/logs
RUSTFS_DATA_DIR=/opt/interview-guide/rustfs/data
RUSTFS_LOGS_DIR=/opt/interview-guide/rustfs/logs
BACKEND_LOG_DIR=/opt/interview-guide/agent/logs
